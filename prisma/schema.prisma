// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // url = "postgresql://incahoots3d:rupertbear@localhost:5432/incahoots3d?schema=incahoots3d"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ModelOrder {
  id                      Int                @id @default(autoincrement())
  shopify_cust_id         String
  shopify_order_id        String
  order_number            String
  customer_email          String
  customer_first_name     String
  customer_last_name      String
  size_cm                 Int
  colour                  Colour
  upload_token            String             @unique
  review_token            String?            @unique
  requires_manual_review  Boolean            @default(false)
  in_error_state          Boolean            @default(false)
  error_info              String?
  order_status            OrderStatus
  customer_action_message String?
  placed                  DateTime
  ModelOrderInputs        ModelOrderInputs[]
  ModelGenerations        ModelGenerations[]
}

model ModelOrderInputs {
  id           Int        @id @default(autoincrement())
  ModelOrder   ModelOrder @relation(fields: [modelOrderId], references: [id])
  modelOrderId Int
  image_type   ImageType
  url          String
  uploaded     DateTime
}

model ModelGenerations {
  id             Int        @id @default(autoincrement())
  ModelOrder     ModelOrder @relation(fields: [modelOrderId], references: [id])
  modelOrderId   Int
  selectedByCust Boolean    @default(false)
  generated      DateTime
  glbUrl         String?
  stlUrl         String?
  mf3Url         String?
}

enum ImageType {
  PNG
  JPG
  WEBP
}

enum Colour {
  white
  black
  grey
}

enum OrderStatus {
  PURCHASED
  AWAITING_IMAGE
  CUSTOMER_IMAGE_UPLOADED
  IMAGE_FAILED_VALIDATION
  IMAGE_PREPROCESSED
  MODEL_GENERATED
  POST_PROCESSED
  MODEL_QA_COMPLETE
  AWAITING_CHOICE
  MODEL_SELECTED
  CANCELLED
}
